{
  "name": "ripit-fitness",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "lint:biome": "biome check .",
    "lint:all": "biome check . && eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paralleldrive/cuid2": "^2.3.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@serwist/next": "^9.5.6",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.4.19",
    "bullmq": "^5.70.1",
    "lucide-react": "^0.562.0",
    "next": "16.0.7",
    "pg": "^8.19.0",
    "pino": "^10.3.0",
    "react": "19.2.0",
    "minio": "^8.0.7",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/postcss": "^4",
    "@testcontainers/gcloud": "^11.11.0",
    "@testcontainers/postgresql": "^10.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.19.25",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.3.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.0",
    "serwist": "^9.5.6",
    "tailwindcss": "^4",
    "testcontainers": "^10.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "description": "A focused strength training tracker that lets you import programs from CSV and track workouts without rigid app constraints.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "bash scripts/check-file-length.sh"
    ]
  },
  "//lint-staged-note": "Biome runs on staged files via .husky/pre-commit before lint-staged",
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }

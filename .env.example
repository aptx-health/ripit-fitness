# Ripit Fitness Environment Configuration
# Copy this file to .env and configure for your setup

# ⚠️ IMPORTANT: If you have .env.local or other .env.* files, they will
# override values in this file! Update ALL .env files or delete the extras.
# File precedence: .env < .env.local < .env.development < .env.development.local

# =============================================================================
# Authentication - Choose ONE option:
# =============================================================================

# Option A: Mock Auth (Local Development - No Supabase Account Needed!)
# Bypasses Supabase Auth entirely for quick local testing
USE_MOCK_AUTH=true
MOCK_USER_ID=dev-user-local

# Option B: Real Supabase Auth (Production & Realistic Testing)
# Comment out USE_MOCK_AUTH and provide Supabase credentials below
# USE_MOCK_AUTH=false

# =============================================================================
# Database - Choose ONE option:
# =============================================================================

# Local PostgreSQL (Docker)
# Run: docker run -d --name ripit-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=ripit -p 5433:5432 postgres:15
# Note: Using port 5433 to avoid conflicts with existing PostgreSQL installations
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ripit"

# Testing with testcontainers (leave empty, testcontainers will set this)
# DATABASE_URL=""

# =============================================================================
# Application Settings
# =============================================================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# BetterAuth (used alongside or instead of Supabase Auth)
# =============================================================================
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# =============================================================================
# Logging Configuration
# =============================================================================
# Server-side logging level (API routes, server components)
# Levels: trace(10) | debug(20) | info(30) | warn(40) | error(50) | fatal(60) | silent
# Set to "debug" to see detailed completion flow logs, "info" for production
PINO_LOG_LEVEL="info"

# Client-side logging level (browser, client components)
# Levels: debug | info | warn | error | silent
# Set to "debug" to see detailed client-side logs
NEXT_PUBLIC_LOG_LEVEL="info"

# =============================================================================
# PowerSync (Optional - only if using PowerSync integration)
# =============================================================================
# NEXT_PUBLIC_POWERSYNC_URL="https://xxxx.powersync.journeyapps.com"
# POWERSYNC_2_SUPABASE="your-powersync-key"
